# Required for live Amap Web Service API calls.
# Select the "Web Service" platform when creating this key. Never commit it.
AMAP_WEB_KEY=

# Optional. Used only for manual review through Amap MCP.
# Amap MCP also requires a "Web Service" key; use the SAME key as AMAP_WEB_KEY.
# The automated data pipeline does not require this value.
AMAP_MCP_KEY=
